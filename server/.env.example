# ============================================================
# APS Mobile — Servidor Intermediário
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no repositório
# ============================================================

# Chave da API OpenWeatherMap (obrigatório)
# Obtenha gratuitamente em: https://openweathermap.org/api
OPENWEATHER_API_KEY=sua_chave_aqui

# Porta do servidor (padrão: 3001)
PORT=3001

# Ambiente: development | production
NODE_ENV=development

# Origens permitidas no CORS (somente em produção, separadas por vírgula)
# Exemplo: ALLOWED_ORIGINS=https://seuapp.com,https://seuapp2.com
# Em desenvolvimento, todas as origens são aceitas automaticamente
ALLOWED_ORIGINS=
